{
  "name": "web-teca",
  "version": "1.0.0",
  "description": "Landing page TECA Muebles",
  "main": "server.js",
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./public/css/output.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./public/css/output.css --watch",
    "start": "node server.js",
    "dev": "concurrently \"npm run watch:css\" \"nodemon server.js\""
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.4.0"
  }
}
